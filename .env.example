# =============================================================================
# PM Studio — Environment Variables
# Copy this file to .env at the project root and fill in values.
#
# Local dev:  use localhost hostnames (see defaults below).
# Docker full stack: use postgres / redis hostnames (see DEPLOY.md).
# =============================================================================

# --- Database (required) ---
DATABASE_URL=postgresql+asyncpg://pmstudio:devpassword123@localhost:5432/pmstudio
SYNC_DATABASE_URL=postgresql://pmstudio:devpassword123@localhost:5432/pmstudio

# --- Redis / Celery (required) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT (required) ---
# Use a random string of at least 32 characters in production.
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI providers (optional — at least one recommended for generation) ---
# Keys here are server-wide fallbacks. Per-org overrides can also be set in
# Studio -> Admin -> AI config (stored in PostgreSQL).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
DEEPSEEK_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_API_KEY=
HUGGINGFACE_API_KEY=
AIMLAPI_API_KEY=
SILICONFLOW_API_KEY=
ALIBABA_API_KEY=
GITHUB_API_KEY=

# --- App ---
ENVIRONMENT=development
# Comma-separated list for production, e.g. https://studio.example.com,https://portal.example.com
ALLOWED_ORIGINS=http://localhost:3000

# --- File storage (optional — falls back to backend/uploads/) ---
UPLOAD_DIR=uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=

# --- Frontend (Docker / production build only) ---
# Set when building the frontend image or in frontend/.env.local for custom API host.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# GitHub repo push for the Build code factory (fine-grained PAT:
# scopes = Administration:write (repo create) + Contents:write + Workflows:write)
GITHUB_REPO_TOKEN=
GITHUB_OWNER=
