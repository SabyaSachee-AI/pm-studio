# =============================================================================
# PM Studio — Contabo VPS (.env)
# Auto-generated by scripts/setup-contabo.sh — do not edit template; edit .env
# AI keys: add later in Studio → Admin → AI config (not required here)
# =============================================================================

# --- Database (Docker service: postgres) ---
DATABASE_URL=postgresql+asyncpg://pmstudio:__DB_PASSWORD__@postgres:5432/pmstudio
SYNC_DATABASE_URL=postgresql://pmstudio:__DB_PASSWORD__@postgres:5432/pmstudio

# --- Redis / Celery (Docker service: redis) ---
REDIS_URL=redis://redis:6379/0

# --- JWT (auto-generated on setup) ---
JWT_SECRET=__JWT_SECRET__
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI providers (optional — configure in Admin → AI config UI instead) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
DEEPSEEK_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_API_KEY=
HUGGINGFACE_API_KEY=
AIMLAPI_API_KEY=
SILICONFLOW_API_KEY=
ALIBABA_API_KEY=
GITHUB_API_KEY=

# --- App ---
# development = login works over HTTP (IP:8090). Use production only with HTTPS.
ENVIRONMENT=development
ALLOWED_ORIGINS=__PUBLIC_URL__

# --- File storage ---
UPLOAD_DIR=uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=

# --- Frontend (browser URL via nginx) ---
NEXT_PUBLIC_API_URL=__PUBLIC_URL__/api/v1
